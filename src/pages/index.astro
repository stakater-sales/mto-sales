---
// MTO Enterprise Pitch — Stakater Multi-Tenant Operator
// Audience: Platform leads, CTOs, infrastructure architects
// Theme: matches SCO Hyperscaler Engine design system
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Stakater MTO — Enterprise Kubernetes Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    /* ── Design tokens ── */
    :root {
      --primary: #EA7845;
      --primary-light: #FDF3EE;
      --primary-mid: #F5C4A8;
      --dark: #111827;
      --gray: #6B7280;
      --light-gray: #E5E7EB;
      --bg: #FFFFFF;
      --bg-light: #F9FAFB;
      --red-hat: #E00000;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      width: 100%; height: 100%;
      font-family: 'Inter', sans-serif;
      background: #1a1a1a;
      overflow: hidden;
    }

    /* ── Slide container ── */
    .deck {
      width: 100vw;
      height: 100vh;
      position: relative;
    }

    section {
      position: absolute;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      background: var(--bg);
      padding: 60px 80px;
    }

    section.active {
      display: flex;
    }

    section.section-light {
      background: var(--bg-light);
    }

    section.cta {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      color: white;
    }

    section.cta h1, section.cta h2, section.cta p { color: white; }
    section.cta .highlight { color: var(--primary); }

    .container {
      width: 100%;
      max-width: 1100px;
    }

    /* ── Typography ── */
    h1 {
      font-size: 52px;
      font-weight: 900;
      line-height: 1.1;
      color: var(--dark);
      letter-spacing: -1px;
    }

    h2 {
      font-size: 28px;
      font-weight: 700;
      line-height: 1.3;
      color: var(--dark);
    }

    h3 {
      font-size: 20px;
      font-weight: 700;
      color: var(--dark);
    }

    p {
      font-size: 18px;
      line-height: 1.65;
      color: var(--gray);
      max-width: 720px;
    }

    em { font-style: italic; color: var(--gray); }

    .highlight {
      color: var(--primary);
    }

    /* ── Logo ── */
    .logo {
      position: fixed;
      top: 24px;
      left: 32px;
      z-index: 100;
      opacity: 0.85;
    }

    .logo img { height: 32px; width: auto; }

    /* ── Slide counter ── */
    .slide-counter {
      position: fixed;
      bottom: 20px;
      right: 32px;
      font-size: 13px;
      color: #9CA3AF;
      z-index: 100;
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    /* ── Nav dots ── */
    .nav-dots {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      z-index: 100;
    }

    .nav-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #D1D5DB;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }

    .nav-dot.active {
      background: var(--primary);
      transform: scale(1.3);
    }

    /* ── Cards ── */
    .card {
      background: white;
      border: 1.5px solid var(--light-gray);
      border-radius: 14px;
      padding: 28px 32px;
    }

    .card.accented {
      border-color: var(--primary);
      background: var(--primary-light);
    }

    /* ── Pill tags ── */
    .pill {
      display: inline-block;
      background: var(--bg-light);
      border: 1px solid var(--light-gray);
      border-radius: 100px;
      padding: 5px 16px;
      font-size: 14px;
      font-weight: 600;
      color: var(--dark);
    }

    .pill.primary {
      background: var(--primary-light);
      border-color: var(--primary-mid);
      color: var(--primary);
    }

    /* ── Two-column grid ── */
    .col-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 50px;
    }

    .col-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 36px;
    }

    /* ── Divider line ── */
    .vdivider {
      border-left: 3px solid var(--primary);
      padding-left: 32px;
    }

    /* ── Flow arrow ── */
    .flow-arrow {
      display: flex;
      align-items: center;
      color: var(--light-gray);
      font-size: 32px;
      font-weight: 300;
    }

    /* ── Stat callout ── */
    .stat {
      text-align: center;
    }
    .stat .number {
      font-size: 56px;
      font-weight: 900;
      color: var(--primary);
      line-height: 1;
    }
    .stat .label {
      font-size: 15px;
      color: var(--gray);
      margin-top: 6px;
      font-weight: 500;
    }

    /* ── Cluster diagram ── */
    .cluster-chaos {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .cluster-box {
      border: 2px solid var(--light-gray);
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
      font-weight: 600;
      color: var(--gray);
      text-align: center;
      min-width: 90px;
    }

    .cluster-box.stressed {
      border-color: #FCA5A5;
      background: #FEF2F2;
      color: #DC2626;
    }

    /* ── Tenant model diagram ── */
    .tenant-model {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
    }

    .tenant-cluster {
      width: 100%;
      border: 2.5px solid var(--primary);
      border-radius: 14px;
      padding: 20px 28px;
      background: var(--primary-light);
    }

    .tenant-row {
      display: flex;
      gap: 10px;
      margin-top: 14px;
    }

    .tenant-tag {
      flex: 1;
      background: white;
      border: 1.5px solid var(--primary-mid);
      border-radius: 8px;
      padding: 10px;
      text-align: center;
      font-size: 13px;
      font-weight: 600;
      color: var(--dark);
    }

    /* ── Pillar cards ── */
    .pillar-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .pillar-card {
      background: white;
      border: 1.5px solid var(--light-gray);
      border-radius: 12px;
      padding: 22px 24px;
      position: relative;
    }

    .pillar-card.featured {
      border-color: var(--primary);
      background: var(--primary-light);
    }

    .pillar-icon {
      font-size: 26px;
      margin-bottom: 10px;
    }

    .pillar-name {
      font-size: 17px;
      font-weight: 800;
      color: var(--dark);
      margin-bottom: 6px;
    }

    .pillar-tagline {
      font-size: 13px;
      color: var(--gray);
      line-height: 1.5;
    }

    .pillar-badge {
      position: absolute;
      top: 14px;
      right: 14px;
      background: var(--primary);
      color: white;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 100px;
      letter-spacing: 0.5px;
    }

    /* ── Before/After table ── */
    .comparison {
      width: 100%;
      border-collapse: collapse;
      border-radius: 12px;
      overflow: hidden;
    }

    .comparison th {
      padding: 16px 24px;
      font-size: 16px;
      font-weight: 800;
      text-align: left;
    }

    .comparison th.before {
      background: #FEF2F2;
      color: #DC2626;
      width: 50%;
    }

    .comparison th.after {
      background: var(--primary-light);
      color: var(--primary);
      width: 50%;
    }

    .comparison td {
      padding: 13px 24px;
      font-size: 16px;
      color: var(--dark);
      border-top: 1px solid var(--light-gray);
      vertical-align: top;
    }

    .comparison td.before {
      background: #FFFBFB;
      color: #6B7280;
    }

    .comparison td.after {
      background: #FDFAF8;
      color: var(--dark);
      font-weight: 600;
    }

    /* ── Adoption steps ── */
    .steps {
      display: flex;
      gap: 0;
      align-items: stretch;
    }

    .step {
      flex: 1;
      padding: 28px 24px;
      position: relative;
    }

    .step:not(:last-child)::after {
      content: '→';
      position: absolute;
      right: -14px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 24px;
      color: var(--primary);
      z-index: 1;
    }

    .step-num {
      width: 36px;
      height: 36px;
      background: var(--primary);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 800;
      margin-bottom: 14px;
    }

    .step-title {
      font-size: 18px;
      font-weight: 800;
      color: var(--dark);
      margin-bottom: 8px;
    }

    .step-detail {
      font-size: 14px;
      color: var(--gray);
      line-height: 1.6;
    }

    /* ── Build vs buy ── */
    .bvb-row {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 14px 0;
      border-bottom: 1px solid var(--light-gray);
    }

    .bvb-row:last-child { border-bottom: none; }

    .bvb-label {
      font-size: 15px;
      font-weight: 700;
      color: var(--dark);
      min-width: 200px;
    }

    .bvb-diy {
      flex: 1;
      font-size: 14px;
      color: #9CA3AF;
    }

    .bvb-mto {
      flex: 1;
      font-size: 14px;
      color: var(--dark);
      font-weight: 600;
    }

    /* ── Certifications/badges ── */
    .cert-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 2px solid var(--light-gray);
      border-radius: 12px;
      padding: 14px 22px;
      background: white;
    }

    .cert-badge .cert-icon {
      font-size: 28px;
    }

    .cert-badge .cert-text {
      font-size: 15px;
      font-weight: 700;
      color: var(--dark);
    }

    /* ── Outcome badges ── */
    .outcome-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .outcome-badge {
      background: var(--primary-light);
      border: 1.5px solid var(--primary-mid);
      border-radius: 10px;
      padding: 10px 18px;
      font-size: 15px;
      font-weight: 700;
      color: var(--primary);
    }

    /* ── Slide-specific: Title slide ── */
    .title-eyebrow {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 20px;
    }

    .title-sub {
      font-size: 22px;
      color: var(--gray);
      font-weight: 400;
      margin-top: 16px;
      max-width: 600px;
    }

    /* ── Detail problem/solution blocks ── */
    .ps-block {
      background: white;
      border: 1.5px solid var(--light-gray);
      border-radius: 12px;
      overflow: hidden;
    }

    .ps-header {
      padding: 12px 20px;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .ps-header.problem { background: #FEF2F2; color: #DC2626; }
    .ps-header.solution { background: var(--primary-light); color: var(--primary); }

    .ps-body {
      padding: 16px 20px;
      font-size: 15px;
      color: var(--dark);
      line-height: 1.6;
    }

    /* ── Quote block ── */
    .quote-block {
      border-left: 4px solid var(--primary);
      padding: 16px 24px;
      background: var(--primary-light);
      border-radius: 0 12px 12px 0;
    }

    .quote-block p {
      font-size: 20px;
      font-style: italic;
      color: var(--dark);
      font-weight: 500;
    }

    /* ── Key line / tagline ── */
    .key-line {
      font-size: 24px;
      font-weight: 800;
      color: var(--dark);
      line-height: 1.3;
    }

    /* ── spacer ── */
    .sp { display: block; }
    .sp-sm { height: 20px; }
    .sp-md { height: 36px; }
    .sp-lg { height: 52px; }
    .sp-xl { height: 70px; }
  </style>
</head>
<body>

<!-- Fixed logo -->
<div class="logo">
  <img src="/stakater-logo.png" alt="Stakater" />
</div>

<!-- Slide counter -->
<div class="slide-counter" id="slideCounter">1 / 19</div>

<!-- Nav dots -->
<nav class="nav-dots" id="navDots"></nav>

<div class="deck" id="deck">

  <!-- ═══════════════════════════════════════════════
       SLIDE 0 — Title
  ═══════════════════════════════════════════════ -->
  <section class="active">
    <div class="container">
      <div class="title-eyebrow">Stakater Multi-Tenant Operator</div>
      <h1>
        From Kubernetes Clusters<br/>
        to <span class="highlight">Enterprise Platform</span>
      </h1>
      <p class="title-sub">
        Turning complexity into control, governance, and scale —<br/>
        without building it yourself.
      </p>
      <span class="sp sp-xl"></span>
      <div style="display:flex; gap:16px; flex-wrap:wrap;">
        <span class="pill primary">Red Hat Certified Operator</span>
        <span class="pill">OpenShift Native</span>
        <span class="pill">AKS Compatible</span>
        <span class="pill">Any Kubernetes Distribution</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SLIDE 1 — The Multi-Cluster Trap
  ═══════════════════════════════════════════════ -->
  <section class="section-light">
    <div class="container">
      <h1>
        The Strategy That<br/>
        Seems Right — <span class="highlight">But Fails</span>
      </h1>
      <span class="sp sp-md"></span>
      <div class="col-2" style="align-items:start;">
        <div>
          <div class="quote-block">
            <p>"Let's give each team their own cluster.<br/>That ensures isolation and flexibility."</p>
          </div>
          <span class="sp sp-md"></span>
          <p style="font-size:17px;">Sounds right on day one.<br/>By month six, the truth arrives.</p>
          <span class="sp sp-md"></span>
          <div class="cluster-chaos">
            <div class="cluster-box">Team A<br/>cluster</div>
            <div class="cluster-box">Team B<br/>cluster</div>
            <div class="cluster-box">Team C<br/>cluster</div>
            <div class="cluster-box stressed">Team D<br/>cluster</div>
            <div class="cluster-box stressed">Team E<br/>cluster</div>
            <div class="cluster-box stressed">Team F<br/>cluster</div>
            <div class="cluster-box stressed" style="font-size:12px;">Team G<br/>cluster ⚠</div>
            <div class="cluster-box stressed" style="font-size:11px; color:#991B1B;">Cluster N…<br/>⚠ ⚠</div>
          </div>
          <span class="sp sp-sm"></span>
          <p style="font-size:14px; color:#DC2626; font-weight:600;">10 → 50 → 100 clusters. Each needs upgrades, policies, access control, monitoring.</p>
        </div>
        <div class="vdivider">
          <h3 style="color:var(--gray); font-weight:600; margin-bottom:18px;">What actually happens</h3>
          <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="card">
              <div style="font-size:14px; font-weight:800; color:#DC2626; margin-bottom:4px;">NO STANDARDIZATION</div>
              <div style="font-size:15px; color:var(--dark);">Every cluster is a snowflake. Policies drift. Security baselines diverge.</div>
            </div>
            <div class="card">
              <div style="font-size:14px; font-weight:800; color:#DC2626; margin-bottom:4px;">COSTS EXPLODE</div>
              <div style="font-size:15px; color:var(--dark);">Duplicated tooling, idle nodes, no chargeback. Finance can't explain the bill.</div>
            </div>
            <div class="card">
              <div style="font-size:14px; font-weight:800; color:#DC2626; margin-bottom:4px;">PLATFORM TEAM BURNS OUT</div>
              <div style="font-size:15px; color:var(--dark);">Every new team = manual cluster setup. The bottleneck becomes the platform team itself.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SLIDE 2 — Where This Always Leads
  ═══════════════════════════════════════════════ -->
  <section>
    <div class="container">
      <h1>
        This Is Not a<br/>
        Future Risk. <span class="highlight">This Always Happens.</span>
      </h1>
      <span class="sp sp-lg"></span>
      <div class="col-3">
        <div class="card" style="text-align:center; padding:32px 24px;">
          <div class="stat">
            <div class="number">6×</div>
            <div class="label">more clusters than planned<br/>within 18 months</div>
          </div>
        </div>
        <div class="card" style="text-align:center; padding:32px 24px;">
          <div class="stat">
            <div class="number">40%</div>
            <div class="label">of platform team time spent<br/>on cluster maintenance</div>
          </div>
        </div>
        <div class="card" style="text-align:center; padding:32px 24px;">
          <div class="stat">
            <div class="number">0</div>
            <div class="label">teams with clear cost<br/>visibility per workload</div>
          </div>
        </div>
      </div>
      <span class="sp sp-lg"></span>
      <div class="col-2" style="gap:30px; align-items:start;">
        <div>
          <h3 style="margin-bottom:12px;">Operational cost grows linearly</h3>
          <p style="font-size:16px;">Add a team → add a cluster → add a full operations burden. There is no economy of scale with cluster sprawl.</p>
        </div>
        <div>
          <h3 style="margin-bottom:12px;">Complexity grows exponentially</h3>
          <p style="font-size:16px;">Security policies drift. Tooling duplicates. Audit trails fragment. The more clusters, the harder compliance becomes.</p>
        </div>
      </div>
      <span class="sp sp-md"></span>
      <div class="key-line" style="text-align:center; color:var(--primary);">
        Clusters don't scale. Platforms do.
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SLIDE 3 — The Real Problem (Reframe)
  ═══════════════════════════════════════════════ -->
  <section class="section-light">
    <div class="container">
      <h1>
        You're Solving<br/>
        the <span class="highlight">Wrong Problem</span>
      </h1>
      <span class="sp sp-md"></span>
      <div class="col-2" style="align-items:center; gap:60px;">
        <div>
          <p style="font-size:17px; margin-bottom:24px;">Most teams diagnose the symptom — too many clusters — and prescribe more cluster tooling. That doesn't solve it. It scales the pain.</p>
          <div class="card" style="margin-bottom:16px;">
            <div style="font-size:14px; font-weight:800; color:var(--gray); margin-bottom:6px; letter-spacing:1px;">YOU THINK</div>
            <div style="font-size:18px; font-weight:700; color:var(--dark);">"We need better cluster management"</div>
          </div>
          <div class="card accented">
            <div style="font-size:14px; font-weight:800; color:var(--primary); margin-bottom:6px; letter-spacing:1px;">THE REAL NEED</div>
            <div style="font-size:18px; font-weight:700; color:var(--dark);">A platform layer <em>on top</em> of Kubernetes</div>
          </div>
        </div>
        <div>
          <h3 style="margin-bottom:20px;">Three truths the industry has learned</h3>
          <div style="display:flex; flex-direction:column; gap:14px;">
            <div style="display:flex; gap:14px; align-items:flex-start;">
              <span style="font-size:22px; margin-top:2px;">🚫</span>
              <div>
                <div style="font-weight:800; color:var(--dark); margin-bottom:3px;">Namespace ≠ multi-tenancy</div>
                <div style="font-size:14px; color:var(--gray);">A namespace is a label. Isolation requires policy, network, RBAC, and quotas enforced together.</div>
              </div>
            </div>
            <div style="display:flex; gap:14px; align-items:flex-start;">
              <span style="font-size:22px; margin-top:2px;">🚫</span>
              <div>
                <div style="font-weight:800; color:var(--dark); margin-bottom:3px;">Kubernetes gives primitives, not a platform</div>
                <div style="font-size:14px; color:var(--gray);">RBAC, NetworkPolicy, ResourceQuota — these are building blocks. You still have to assemble the platform.</div>
              </div>
            </div>
            <div style="display:flex; gap:14px; align-items:flex-start;">
              <span style="font-size:22px; margin-top:2px;">🚫</span>
              <div>
                <div style="font-weight:800; color:var(--dark); margin-bottom:3px;">Self-service without guardrails is a compliance risk</div>
                <div style="font-size:14px; color:var(--gray);">Freedom without policy enforcement is just controlled chaos with extra steps.</div>
              </div>
            </div>
          </div>
          <span class="sp sp-md"></span>
          <div class="key-line">This is not a Kubernetes problem.<br/>It's a <span class="highlight">platform problem</span>.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SLIDE 4 — The Platform Model
  ═══════════════════════════════════════════════ -->
  <section>
    <div class="container">
      <h1>
        There Is a<br/>
        <span class="highlight">Better Model</span>
      </h1>
      <span class="sp sp-md"></span>
      <div class="col-2" style="align-items:center; gap:60px;">
        <div>
          <h3 style="color:var(--gray); font-weight:500; margin-bottom:20px;">Instead of many clusters…</h3>
          <div class="cluster-chaos" style="margin-bottom:24px;">
            <div class="cluster-box stressed">Cluster<br/>A</div>
            <div class="cluster-box stressed">Cluster<br/>B</div>
            <div class="cluster-box stressed">Cluster<br/>C</div>
            <div class="cluster-box stressed">Cluster<br/>N…</div>
          </div>
          <div style="display:flex; justify-content:center; align-items:center; gap:12px; color:var(--primary); font-size:32px; margin:16px 0;">↓</div>
          <h3 style="color:var(--dark); margin-bottom:14px;">Few clusters. Many secure tenants.</h3>
          <div class="tenant-model">
            <div class="tenant-cluster">
